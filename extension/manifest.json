{
  "manifest_version": 3,
  "name": "Grabber",
  "version": "0.1.0",
  "description": "Send the current page or link to your local Grabber instance",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grabber",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["activeTab", "storage", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "grabber@stacklis.local",
      "strict_min_version": "115.0"
    },
    "gecko_android": {
      "strict_min_version": "115.0"
    }
  }
}
