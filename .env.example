# Anchor for all download output. User-supplied outputFolder values are resolved
# under this root and rejected if they escape it.
# Default: %USERPROFILE%\Downloads\grabber
# GRABBER_DOWNLOAD_ROOT=

# Binary paths. If unset, grabber sweeps the standard candidates at module load.
# GRABBER_FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# GRABBER_YTDLP_PATH=
# GRABBER_GALLERYDL_PATH=

# Max time a yt-dlp / gallery-dl subprocess is allowed to run before SIGTERM
# (followed by SIGKILL 5s later). Default 15min.
# GRABBER_PROCESS_TIMEOUT_MS=900000

# Max concurrent yt-dlp / gallery-dl subprocesses. Default 4.
# GRABBER_MAX_CONCURRENT=4
